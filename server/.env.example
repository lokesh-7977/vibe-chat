# App
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api/v1
SECRET_KEY=change-me-before-production
ALGORITHM=HS256

# Uploads
UPLOADS_MAX_FILE_SIZE_BYTES=52428800
UPLOADS_ALLOWED_MIME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain,text/markdown,image/jpeg,image/png,image/webp,image/gif,audio/mpeg,audio/mp4,audio/wav,audio/webm,audio/ogg

# CORS (comma-separated). Leave empty to disable.
CORS_ALLOW_ORIGINS=

# AI
NVAPI_API_KEY=
NVAPI_BASE_URL=https://integrate.api.nvidia.com
NVAPI_CHAT_MODEL=mistralai/mistral-7b-instruct-v0.3
RAG_TOP_K=8

# Database
DATABASE_URL=postgresql+psycopg2://localuser:localpassword@localhost:5432/chatapp_db

# Cloudflare R2 (S3-compatible)
# Example endpoint: https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Optional: public URL base if your bucket/objects are publicly accessible (or via Cloudflare public domain)
# Example: https://pub-<hash>.r2.dev/<bucket>  OR  https://files.yourdomain.com
R2_PUBLIC_BASE_URL=

# Presigned URL expiry (seconds)
R2_PRESIGN_EXPIRES_SECONDS=3600
